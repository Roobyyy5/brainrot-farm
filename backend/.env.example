PORT=4000

# Postgres connection string, e.g. postgresql://user:password@host:port/dbname
# Most hosted providers (Supabase, Render, Neon) require SSL — leave PGSSL unset.
DATABASE_URL=postgresql://user:password@host:5432/brainrot_farm
# set to "false" only for a local Postgres without SSL
PGSSL=true

BOT_TOKEN=123456:YOUR_TELEGRAM_BOT_TOKEN
# set to "true" to skip Telegram initData signature check (local dev only)
SKIP_TELEGRAM_AUTH=false

# URL where the frontend (frontend/dist or `npm run dev`) is reachable by Telegram.
# Must be HTTPS in production (use ngrok for local testing).
MINI_APP_URL=https://your-mini-app-domain.example

# Secret required in the x-admin-key header to read GET /admin/stats.
ADMIN_KEY=change-me-to-a-long-random-string
