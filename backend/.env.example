PORT=4000
BOT_TOKEN=123456:YOUR_TELEGRAM_BOT_TOKEN
# set to "true" to skip Telegram initData signature check (local dev only)
SKIP_TELEGRAM_AUTH=false

# URL where the frontend (frontend/dist or `npm run dev`) is reachable by Telegram.
# Must be HTTPS in production (use ngrok for local testing).
MINI_APP_URL=https://your-mini-app-domain.example
